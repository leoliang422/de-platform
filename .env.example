# ============================================================
# de-platform 环境变量示例
# 复制为 .env 并填入真实值（.env 已被 gitignore，切勿提交真实密钥）
# ============================================================

# ---- 后端服务 ----
APP_ENV=local                       # local | staging | production
APP_SECRET_KEY=change-me            # JWT 签名密钥
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 数据库（PostgreSQL / Neon）----
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/de_platform

# ---- Redis（ARQ 队列 / Upstash）----
REDIS_URL=redis://localhost:6379/0

# ---- 投稿加工队列 ----
# false：投稿在请求内同步加工（本地/演示，无需 Redis 与 Worker）
# true ：投稿入 ARQ 队列，由独立 Worker 异步加工（生产）
TASK_QUEUE_ENABLED=false

# ---- 大模型（豆包 / 火山方舟 Ark，OpenAI 兼容）----
LLM_PROVIDER=mock                   # mock | doubao（无 key 时自动回退 mock）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-4k

# ---- 支付（骨架）----
PAYMENT_PROVIDER=mock               # mock | wechat | alipay | stripe（后续）

# ---- 管理员种子账号 ----
# scripts/seed.py 会创建：admin@example.com / admin12345（仅本地演示，生产请改）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ---- 前端 ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
