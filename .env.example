# ============================================================
# de-platform 环境变量示例
# 复制为 .env 并填入真实值（.env 已被 gitignore，切勿提交真实密钥）
# ============================================================

# ---- 后端服务 ----
APP_ENV=local                       # local | staging | production
APP_SECRET_KEY=change-me            # JWT 签名密钥
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 数据库（PostgreSQL / Neon）----
# 本地无 Docker 可用 SQLite：sqlite+aiosqlite:///./dev.db
# 生产（Neon）直接粘贴其连接串即可，代码会自动适配 asyncpg + SSL：
#   DATABASE_URL=postgresql://user:pwd@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/de_platform

# ---- CORS（生产必填）----
# 允许访问后端的前端域名，逗号分隔；本地默认 http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ---- Redis（ARQ 队列 / Upstash）----
REDIS_URL=redis://localhost:6379/0

# ---- 投稿加工队列 ----
# false：投稿在请求内同步加工（本地/演示，无需 Redis 与 Worker）
# true ：投稿入 ARQ 队列，由独立 Worker 异步加工（生产）
TASK_QUEUE_ENABLED=false

# ---- 文件/图片存储 ----
# local：存本地磁盘，后端 /uploads 提供访问（默认，零外部依赖；Render 磁盘临时）
# s3   ：S3 兼容对象存储（R2/TOS/MinIO）；凭证未配齐时自动回退 local
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=uploads
STORAGE_PUBLIC_BASE_URL=            # 留空则用请求 base_url 拼接；跨域部署可填后端公网地址
# S3 兼容对象存储（获取方式见 docs/deployment.md「文件存储」）
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=                 # 例：https://cdn.example.com 或 R2 公开访问域名

# ---- 前端站点根地址（用于邮件里的重置/验证链接）----
FRONTEND_BASE_URL=http://localhost:3000

# ---- 邮件发送 ----
# mock：不真正发信，仅记录日志；找回密码接口会返回 dev token 便于本地自测
# smtp：真实 SMTP；凭证未配齐时自动回退 mock。获取方式见 docs/deployment.md「邮件发送」
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ---- 大模型（豆包 / 火山方舟 Ark，OpenAI 兼容）----
LLM_PROVIDER=mock                   # mock | doubao（无 key 时自动回退 mock）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-4k

# ---- 支付 ----
# mock：同步结算，本地/演示默认，无需任何凭证。
# wechat / alipay：真实通道；凭证未配齐时会自动回退 mock（不影响现有功能）。
# 凭证获取方式详见 docs/deployment.md「支付接入」。
PAYMENT_PROVIDER=mock

# 微信支付（v3 Native 扫码）
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY_PATH=
WECHAT_NOTIFY_URL=                  # 例：https://your-api.onrender.com/payment/webhook/wechat

# 支付宝（电脑/手机网站支付）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=                  # 例：https://your-api.onrender.com/payment/webhook/alipay

# ---- 管理员种子账号 ----
# scripts/seed.py 会创建：admin@example.com / admin12345（仅本地演示，生产请改）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ---- 前端 ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
